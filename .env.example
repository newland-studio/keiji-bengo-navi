# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# WordPress ローカル環境（Local WP のデフォルトURL）
WP_URL=http://keiji-bengo-navi.local
WP_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Cloudflare
CF_API_TOKEN=...
CF_ACCOUNT_ID=...

# Simply Static 出力先（WP管理画面 Simply Static > Settings と合わせること）
STATIC_EXPORT_DIR=./static-export

# WP-CLI 使用フラグ（true=高速ローカル投入 / false=REST API fallback）
USE_WPCLI=true
